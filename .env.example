# ورود پنل مدیریت (/admin) — حتماً مقادیر قوی بگذارید
ADMIN_USER= X
ADMIN_PASSWORD=یک-رمز-قوی-اینجا

# ---------- دیتابیس ----------
# اگر DATABASE_URL ست شود، از PostgreSQL استفاده می‌شود (برای هاست/رانفلر).
# در نبود آن، به‌صورت خودکار از SQLite محلی (پوشه‌ی data) استفاده می‌شود.
# DATABASE_URL=postgres://user:password@host:5432/dbname
# اگر هاست SSL می‌خواهد:
# PGSSL=true

# مسیر ذخیره‌ی عکس/ویدیوهای آپلودی و (در حالت محلی) فایل SQLite
# روی هاست، دیسک ماندگار را اینجا مونت کنید:
# DATA_DIR=/app/data
